# MongoDB Configuration
# For Local Development:
MONGO_URI=mongodb://127.0.0.1:27017/it_business_app

# For Vercel Production (MongoDB Atlas):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/it_business_app?retryWrites=true&w=majority
# Or use MONGODB_URI (Vercel's default)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/it_business_app?retryWrites=true&w=majority

# JWT Secret (Generate a random secure string)
JWT_SECRET=your_super_secret_jwt_key_here

# Server Port
PORT=3000

# Environment
NODE_ENV=development
